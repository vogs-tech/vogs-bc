# Program IDs (update after anchor deploy)
VOGS_HOOK_PROGRAM_ID=VHook1111111111111111111111111111111111111
VOGS_VAULT_PROGRAM_ID=VVau1t111111111111111111111111111111111111
VOGS_SETTLEMENT_PROGRAM_ID=VSett1e111111111111111111111111111111111111
VOGS_STREAMS_PROGRAM_ID=VStrm1111111111111111111111111111111111111
VOGS_COLLATERAL_PROGRAM_ID=VCo11at11111111111111111111111111111111111

# Civic Gateway Network (for Transfer Hook KYC)
CIVIC_GATEKEEPER_NETWORK=your-civic-gatekeeper-network-pubkey
